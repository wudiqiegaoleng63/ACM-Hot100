{
  "name": "acm-hot100-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "api:lint": "redocly lint ../../packages/contracts/openapi.yaml --config ../../packages/contracts/redocly.yaml",
    "api:docs": "redocly build-docs ../../packages/contracts/openapi.yaml --config ../../packages/contracts/redocly.yaml --output api-docs.html"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.10",
    "@tanstack/react-query": "^5.80.7",
    "katex": "^0.17.0",
    "lucide-react": "^0.522.0",
    "monaco-editor": "0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.57.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.6.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.1.10",
    "zod": "^4.4.3"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "3.4.12"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.53.1",
    "@redocly/cli": "2.39.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.29.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
