APP_ENV=development
APP_BASE_URL=http://localhost:5173
API_ADDR=:8080
TRUSTED_PROXIES=

MYSQL_DSN=app:app@tcp(localhost:3306)/acmhot100?charset=utf8mb4&parseTime=True&loc=UTC
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=local-redis-password
REDIS_DB=0
REDIS_KEY_PREFIX=acmhot100:

JWT_ISSUER=acmhot100
JWT_ACCESS_AUDIENCE=acmhot100-web
JWT_REFRESH_AUDIENCE=acmhot100-refresh
JWT_ACCESS_SECRET=change-me-to-at-least-32-bytes-random-value
JWT_REFRESH_SECRET=change-me-to-different-32-bytes-random-value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

MAIL_MODE=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=ACM Hot 100 <no-reply@example.local>
SMTP_TLS_MODE=none

JUDGE_MODE=mock
JUDGE0_BASE_URL=http://127.0.0.1:2358

# Optional host port overrides for full-stack Compose
WEB_PORT=5173
API_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025
MYSQL_ROOT_PASSWORD=change-me-local-root-password
MYSQL_PASSWORD=change-me-local-app-password

# Required only with: docker compose --profile judge0 ...
JUDGE0_PORT=2358
JUDGE0_POSTGRES_PASSWORD=change-me-judge0-postgres-password
JUDGE0_REDIS_PASSWORD=change-me-judge0-redis-password
